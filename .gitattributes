# Git Large File Storage (LFS) configuration
# Large files that should be managed by Git LFS

# Executable files (large binaries)
*.exe filter=lfs diff=lfs merge=lfs -text

# Large media files
*.mp4 filter=lfs diff=lfs merge=lfs -text
*.avi filter=lfs diff=lfs merge=lfs -text
*.mov filter=lfs diff=lfs merge=lfs -text

# Archive files
*.zip filter=lfs diff=lfs merge=lfs -text
*.tar filter=lfs diff=lfs merge=lfs -text
*.gz filter=lfs diff=lfs merge=lfs -text


# Virtual machine/container images
*.iso filter=lfs diff=lfs merge=lfs -text
*.ova filter=lfs diff=lfs merge=lfs -text
*.vmdk filter=lfs diff=lfs merge=lfs -text


# Database files
*.db filter=lfs diff=lfs merge=lfs -text
*.sqlite filter=lfs diff=lfs merge=lfs -text


# Machine learning models
*.pkl filter=lfs diff=lfs merge=lfs -text
*.h5 filter=lfs diff=lfs merge=lfs -text
*.pt filter=lfs diff=lfs merge=lfs -text


# Auto-generated files (should not be tracked)
.DS_Store
Thumbs.db
desktop.ini


# Text files (should be tracked normally)
*.md text
*.txt text
*.json text
*.py text
*.js text
*.html text
*.css text
*.xml text
*.yaml text
*.yml text
*.toml text
*.ini text
*.cfg text
*.conf text